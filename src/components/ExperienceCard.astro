---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"experience">;
}

const { entry } = Astro.props;
const { title, role, company, period, summary } = entry.data;
const href = `${import.meta.env.BASE_URL}experience/${entry.id}/`;
---

<article class="card">
  <div class="card__body">
    <p class="timeline__period">{period}</p>
    <h3 class="card__title">
      <a href={href}>{title}</a>
    </h3>
    <p class="timeline__company">
      <strong>{role}</strong> — {company}
    </p>
    <p class="card__summary">{summary}</p>
    <div class="card__footer">
      <a href={href} class="btn btn--ghost">Read case study</a>
    </div>
  </div>
</article>
