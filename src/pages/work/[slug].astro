---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { asset } from "../../lib/urls";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, summary, tools, image, imageAlt, links } = project.data;
---

<BaseLayout title={title} description={summary}>
  <article class="section">
    <div class="container prose">
      <header class="section__header">
        <div class="card__tools" style="margin-bottom: 1rem;">
          {tools.map((t) => (
            <span class="chip">{t}</span>
          ))}
        </div>
        <h1>{title}</h1>
        <p>{summary}</p>
      </header>

      <div class="project-hero">
        <img src={asset(image)} alt={imageAlt} width="1140" height="700" />
      </div>

      {
        links.length > 0 && (
          <div class="project-links">
            {links.map((link) => (
              <a
                href={link.url}
                class={link.primary ? "btn btn--primary" : "btn btn--ghost"}
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.label}
              </a>
            ))}
          </div>
        )
      }

      <Content />

      <p style="margin-top: 2rem;">
        <a href={`${import.meta.env.BASE_URL}`}>← Back to home</a>
      </p>
    </div>
  </article>
</BaseLayout>
